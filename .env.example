# ═══════════════════════════════════════════════════════════════════
# Variables del backend (van en Vercel del onboarding)
# ═══════════════════════════════════════════════════════════════════

# Google OAuth — del proyecto Google Cloud (CREDENTIALS → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel KV (auto-seteadas cuando conectás KV al proyecto)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Token admin (random largo, lo usás para que provision.py acceda)
ADMIN_TOKEN=

# Mail de notificación a TI cuando llega un pedido nuevo
ADMIN_NOTIFY_EMAIL=nacho.rodriguezpirotta@gmail.com
# Refresh token de la cuenta Gmail desde la que mandás notificaciones
# (podés usar el mismo token del sistema Revolv: token_mail.json → refresh_token)
NOTIFY_MAIL_REFRESH_TOKEN=
NOTIFY_MAIL_CLIENT_ID=
NOTIFY_MAIL_CLIENT_SECRET=


# ═══════════════════════════════════════════════════════════════════
# Variables del script local provision.py (van en tu .env local)
# ═══════════════════════════════════════════════════════════════════

# URL pública del onboarding (después del deploy)
ONBOARDING_URL=https://asistente-onboarding.vercel.app
ONBOARDING_ADMIN_TOKEN=
# (el mismo ADMIN_TOKEN de arriba)

# Path al template
TEMPLATE_DIR=/Users/ignaciorodriguezpirotta/Documents/Claude/asistente-template

# Tu user de GitHub (provision.py crea los repos ahí)
GITHUB_OWNER=

# Carpeta donde provision.py crea las instancias de los clientes
CLIENTS_BASE_DIR=/Users/ignaciorodriguezpirotta/Documents/Claude/clients
