{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/start", "destination": "/start.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/mi-pedido", "destination": "/mi-pedido.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/dashboard/:tenant_id", "destination": "/dashboard.html" },
    { "source": "/c/:tenant_id/:client_token", "destination": "/client.html" },
    { "source": "/api/tenant/:id", "destination": "/api/tenant" }
  ]
}
